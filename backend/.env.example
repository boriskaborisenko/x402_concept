PORT=8787

# Frontend origin for CORS
FRONTEND_ORIGIN=http://localhost:5173

# BSC Testnet RPC. Public endpoint is okay for testing, use your own RPC for reliability.
BSC_TESTNET_RPC=https://data-seed-prebsc-1-s1.binance.org:8545

# Put your BSC testnet receiving address here.
BSC_TESTNET_RECEIVER=0x0000000000000000000000000000000000000000

# Put your Algorand testnet receiving address here.
ALGORAND_TESTNET_RECEIVER=REPLACE_WITH_ALGORAND_TESTNET_ADDRESS

# Algonode public endpoints for testing.
ALGORAND_TESTNET_ALGOD=https://testnet-api.algonode.cloud
ALGORAND_TESTNET_INDEXER=https://testnet-idx.algonode.cloud
