# Copy and fill (or edit .env directly — gitignored):
#   cp .env.example .env
#
# Operator EOA — BNB for sweep gas on BSC. Must match OPERATOR in X402Treasury deploy
# and networks[].treasury.contract.sweepOperator in config/config.json.
SWEEP_OPERATOR_PRIVATE_KEY=0xYOUR_OPERATOR_PRIVATE_KEY

PORT=4000
X402_CONFIG=../config/config.json

# Optional: auto Algo→BSC bridge in settlement worker (requires bridge-worker + ALG_TREASURY_MNEMONIC)
# BRIDGE_ALGO_TO_BSC=1
